# Telegram Bot 通知
# 1. 搜尋 @BotFather → /newbot → 取得 token
# 2. 對 Bot 發訊息後打開 https://api.telegram.org/bot<TOKEN>/getUpdates 取得 chat_id
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ──────────────────────────────────────────────────────────
# 永豐證券 Shioaji 整合（僅 prod 機需設；dev 機留空即可）
# 詳細說明：docs/sinopac_setup.md
# ──────────────────────────────────────────────────────────

# 主開關：virtual = 純模擬（dev 預設）；sinopac = 走永豐 API
BROKER_MODE=virtual

# Phase 1 必須維持 true；改為 false 須同時備齊 CA path/password 才會生效
SHIOAJI_SIMULATION=true

# 永豐 Shioaji 個人憑證（申請步驟：https://ai.sinotrade.com.tw/python/Main/index.aspx）
SHIOAJI_API_KEY=
SHIOAJI_SECRET_KEY=
SHIOAJI_PERSON_ID=

# CA 憑證（v1 不啟用；v2 才會用到）。路徑請放在 data/cert/ 內，該目錄已 gitignored
SHIOAJI_CA_PATH=
SHIOAJI_CA_PASSWORD=

# 白名單：哪些 sector_id 走 Sinopac；其他類股強制 VirtualBroker
# 空字串 → 退回 broker_config.yaml 內的 brokers.per_sector
ALLOWED_SECTORS=semiconductor,electronics
